{
  "name": "@querykit/example-drizzle-postgres",
  "private": true,
  "type": "module",
  "scripts": {
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:up": "docker compose up -d --wait postgres",
    "seed": "node --experimental-strip-types src/db/seed.ts",
    "start": "node --experimental-strip-types src/index.ts"
  },
  "dependencies": {
    "@ypanagidis/querykit": "workspace:*",
    "@ypanagidis/querykit-drizzle": "workspace:*",
    "drizzle-orm": "1.0.0-rc.3",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-rc.3"
  }
}
