{
  "name": "querykit-monorepo",
  "version": "0.0.2-alpha.0",
  "private": true,
  "description": "Monorepo for QueryKit packages, apps, and examples.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @ypanagidis/querykit build",
    "dev": "pnpm --filter @ypanagidis/querykit dev",
    "format": "oxfmt -c oxfmt.config.ts 'apps/**/*.ts' 'examples/**/*.ts' 'packages/**/*.ts' '*.json' '*.ts' '*.yaml' 'apps/**/*.json' 'examples/**/*.json' 'packages/**/*.json'",
    "format:check": "oxfmt -c oxfmt.config.ts --check 'apps/**/*.ts' 'examples/**/*.ts' 'packages/**/*.ts' '*.json' '*.ts' '*.yaml' 'apps/**/*.json' 'examples/**/*.json' 'packages/**/*.json'",
    "lint": "oxlint -c oxlint.config.ts --type-aware",
    "lint:fix": "oxlint -c oxlint.config.ts --type-aware --fix",
    "pack:querykit": "pnpm --filter @ypanagidis/querykit pack",
    "publish:alpha": "pnpm --filter @ypanagidis/querykit publish --tag alpha",
    "publish:latest": "pnpm --filter @ypanagidis/querykit publish --tag latest",
    "test": "pnpm --filter @ypanagidis/querykit test",
    "typecheck": "pnpm --filter @ypanagidis/querykit typecheck"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1"
}
