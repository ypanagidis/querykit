{
  "name": "joqi-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for Joqi packages, apps, and examples.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter './packages/*' build && pnpm --filter @joqi/docs build",
    "dev": "pnpm --filter @ypanagidis/joqi dev",
    "dev:docs": "pnpm --filter @joqi/docs dev",
    "format": "oxfmt -c oxfmt.config.ts 'apps/**/*.ts' 'apps/**/*.tsx' '!apps/docs/.source/**/*.ts' '!apps/docs/src/routeTree.gen.ts' 'examples/**/*.ts' 'packages/**/*.ts' '*.json' '*.ts' '*.yaml' 'apps/**/*.json' 'examples/**/*.json' 'packages/**/*.json'",
    "format:check": "oxfmt -c oxfmt.config.ts --check 'apps/**/*.ts' 'apps/**/*.tsx' '!apps/docs/.source/**/*.ts' '!apps/docs/src/routeTree.gen.ts' 'examples/**/*.ts' 'packages/**/*.ts' '*.json' '*.ts' '*.yaml' 'apps/**/*.json' 'examples/**/*.json' 'packages/**/*.json'",
    "lint": "oxlint -c oxlint.config.ts --type-aware",
    "lint:fix": "oxlint -c oxlint.config.ts --type-aware --fix",
    "pack:joqi": "pnpm --filter @ypanagidis/joqi pack",
    "prepare": "effect-language-service patch",
    "publish:alpha": "pnpm --filter @ypanagidis/joqi publish --tag alpha --access public",
    "publish:latest": "pnpm --filter @ypanagidis/joqi publish --tag latest --access public",
    "test": "pnpm --filter './packages/*' test",
    "typecheck": "pnpm --filter @ypanagidis/joqi build && pnpm --filter './packages/*' typecheck && pnpm --filter @joqi/docs typecheck"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "effect-solutions": "0.5.3",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.15.12",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "packageExtensions": {
      "react-remove-scroll@*": {
        "dependencies": {
          "tslib": "2.8.1"
        }
      }
    }
  }
}
